<UserControl x:Class="e_learning_app.Views.CourseDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White"
             PreviewMouseLeftButtonDown="UserControl_PreviewMouseLeftButtonDown">

    <UserControl.Resources>
        <Style x:Key="DocumentBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#F1F5F9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ContextMenu" x:Key="ModernContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" Margin="4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem" x:Key="ModernMenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="6" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="Icon" ContentSource="Icon" VerticalAlignment="Center"/>
                                <ContentPresenter ContentSource="Header" Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator" x:Key="ModernSeparator">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}" Height="{TemplateBinding Height}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="6" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10"/>
                            <TextBlock Text="{TemplateBinding Tag}" Margin="12,0,30,0" VerticalAlignment="Center" Foreground="#94A3B8" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ContentPresenter Margin="12,0,30,0" VerticalAlignment="Center" Content="{TemplateBinding SelectionBoxItem}" IsHitTestVisible="False"/>
                            <Path x:Name="Arrow" Data="M0,0 L4,4 L8,0 Z" Fill="#64748B" HorizontalAlignment="Right" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <ToggleButton Background="Transparent" BorderThickness="0" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorRadioStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}" x:Name="BgEllipse"/>
                            <Path x:Name="CheckIcon" Data="M10,18 L15,23 L26,12" Stroke="White" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ContentItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="White" CornerRadius="12" BorderBrush="#F1F5F9" BorderThickness="1" Padding="15">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Height="240">
                    <Border x:Name="CoverPhoto" VerticalAlignment="Top" Height="180" Background="#3B82F6"/>
                    <Border Width="80" Height="80" Background="White" CornerRadius="15" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="60,0,0,20" BorderBrush="White" BorderThickness="4">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.1"/>
                        </Border.Effect>
                        <TextBlock x:Name="TxtEmoji" Text="📚" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <StackPanel Margin="60,0,60,40">
                    <TextBlock x:Name="TxtTitle" Text="Course Name" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12">
                        <TextBlock x:Name="TxtClassInfo" Text="Class ID" FontSize="14" Foreground="#64748B" VerticalAlignment="Center"/>
                        <TextBlock Text=" • " Foreground="#CBD5E1" VerticalAlignment="Center"/>
                        <Border Background="#EFF6FF" CornerRadius="6" Padding="8,4" BorderBrush="#BFDBFE" BorderThickness="1">
                            <TextBlock x:Name="TxtCategory" Text="Chuyên ngành" FontSize="12" Foreground="#3B82F6" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#F5F3FF" CornerRadius="6" Padding="8,4" BorderBrush="#DDD6FE" BorderThickness="1" Margin="8,0,0,0">
                            <TextBlock x:Name="TxtCourseType" Text="Loại môn" FontSize="12" Foreground="#8B5CF6" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <TextBlock x:Name="TxtDescription" FontSize="15" Foreground="#475569" TextWrapping="Wrap" Margin="0,10,0,30" LineHeight="24"/>

                    <UniformGrid Columns="2" Margin="0,0,0,30" HorizontalAlignment="Left">
                        <StackPanel Width="150">
                            <TextBlock Text="Sinh viên" FontSize="12" Foreground="#94A3B8"/>
                            <TextBlock x:Name="TxtStudentCount" Text="0" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                        </StackPanel>
                        <StackPanel Width="150">
                            <TextBlock Text="Bài tập" FontSize="12" Foreground="#94A3B8"/>
                            <TextBlock x:Name="TxtAssignmentCount" Text="0" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                        </StackPanel>
                    </UniformGrid>

                    <Separator Margin="0,0,0,30" Background="#F1F5F9"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,30,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tài liệu &amp; Nội dung" FontSize="20" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>

                                <Button x:Name="BtnAddContent" Grid.Column="1" Content="+ Thêm mới" Background="#EFF6FF" Foreground="#3B82F6" FontWeight="SemiBold" Padding="16,0" Height="36" MinWidth="100" Cursor="Hand" Visibility="Collapsed" Click="BtnAddContent_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <ListBox x:Name="DocumentsList" Margin="0,20" BorderThickness="0" Background="Transparent" 
                                     ItemContainerStyle="{StaticResource ContentItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     AllowDrop="True" Drop="DocumentsList_Drop" MouseDoubleClick="DocumentsList_MouseDoubleClick">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock x:Name="DragHandle" Grid.Column="0" Text="⋮⋮" FontSize="16" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,15,0" Cursor="SizeAll" MouseLeftButtonDown="DragHandle_PreviewMouseLeftButtonDown" Visibility="{Binding ElementName=BtnAddContent, Path=Visibility}"/>

                                            <Border Grid.Column="1" Width="40" Height="40" Background="#F1F5F9" CornerRadius="8" Margin="0,0,15,0">
                                                <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                <TextBlock Text="{Binding Type}" FontSize="12" Foreground="#94A3B8" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding ElementName=BtnAddContent, Path=Visibility}">
                                                <Button Content="✏️" FontSize="14" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0" ToolTip="Chỉnh sửa" Tag="{Binding Id}" Click="BtnEditContent_Click"/>
                                                <Button Content="🗑️" FontSize="14" Background="Transparent" BorderThickness="0" Cursor="Hand" Foreground="#EF4444" ToolTip="Xóa" Tag="{Binding Id}" Click="BtnDeleteContent_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Bài tập sắp tới" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>
                            <ItemsControl x:Name="AssignmentsList"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Button Content="← Quay lại" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20" Background="#44000000" Foreground="White" Padding="10,5" Cursor="Hand" Click="BtnBack_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Button x:Name="BtnMoreActions" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Background="#44000000" Width="45" Height="32" Cursor="Hand" Click="BtnMoreActions_Click" Visibility="Collapsed">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                        <TextBlock Text="•••" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <Button.ContextMenu>
                <ContextMenu x:Name="CourseContextMenu" Style="{StaticResource ModernContextMenu}">
                    <MenuItem Header="Chỉnh sửa lớp học" Style="{StaticResource ModernMenuItem}" Click="MenuEdit_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="✏️" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuToggleStatus" Header="Kết thúc lớp học" Style="{StaticResource ModernMenuItem}" Click="MenuToggleStatus_Click">
                        <MenuItem.Icon>
                            <TextBlock x:Name="MenuToggleIcon" Text="⏸️" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator Style="{StaticResource ModernSeparator}"/>
                    <MenuItem Header="Xóa lớp học" Foreground="#EF4444" Style="{StaticResource ModernMenuItem}" Click="MenuDelete_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🗑️" FontSize="14" Foreground="#EF4444"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </Button.ContextMenu>
        </Button>

        <Grid x:Name="DeleteOverlay" Visibility="Collapsed">
            <Border Background="#A60F172A" MouseLeftButtonDown="CloseDeleteModal_Click"/>
            <Border Background="White" CornerRadius="24" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <Border Width="64" Height="64" Background="#FEF2F2" CornerRadius="32" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="🗑️" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Xác nhận xóa lớp học?" FontSize="20" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Hành động này không thể hoàn tác. Toàn bộ dữ liệu của lớp học này sẽ bị xóa vĩnh viễn." FontSize="14" Foreground="#64748B" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,30" LineHeight="22"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="2" Content="Hủy bỏ" Height="45" Background="#F1F5F9" Foreground="#475569" FontWeight="SemiBold" Click="CloseDeleteModal_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnConfirmDelete" Grid.Column="0" Content="Xóa vĩnh viễn" Height="45" Background="#EF4444" Foreground="White" FontWeight="SemiBold" Click="ConfirmDelete_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="DeleteContentOverlay" Visibility="Collapsed">
            <Border Background="#A60F172A" MouseLeftButtonDown="CloseDeleteContentModal_Click"/>
            <Border Background="White" CornerRadius="24" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <Border Width="64" Height="64" Background="#FEF2F2" CornerRadius="32" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="🗑️" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Xóa nội dung này?" FontSize="20" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Bạn có chắc chắn muốn xóa tài liệu/nội dung này khỏi lớp học?" FontSize="14" Foreground="#64748B" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,30" LineHeight="22"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="2" Content="Hủy bỏ" Height="45" Background="#F1F5F9" Foreground="#475569" FontWeight="SemiBold" Click="CloseDeleteContentModal_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Grid.Column="0" Content="Xóa vĩnh viễn" Height="45" Background="#EF4444" Foreground="White" FontWeight="SemiBold" Click="ConfirmDeleteContent_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="EditDrawer" Visibility="Collapsed">
            <Border Background="#40000000" MouseLeftButtonDown="CloseEditDrawer_Click"/>
            <Border HorizontalAlignment="Right" Background="White" Width="500">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30">
                        <TextBlock Text="Chỉnh sửa thông tin" FontSize="22" FontWeight="Bold" Margin="0,0,0,25"/>

                        <TextBlock Text="Tên môn học" Foreground="#64748B" Margin="0,0,0,5"/>
                        <TextBox x:Name="EditTitleInput" Style="{StaticResource ModernTextBox}" Height="42" Margin="0,0,0,15"/>

                        <TextBlock Text="Mô tả chi tiết" Foreground="#64748B" Margin="0,0,0,5"/>
                        <TextBox x:Name="EditDescInput" Style="{StaticResource ModernTextBox}" Height="120" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="12,10" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Mã lớp học" Foreground="#64748B" Margin="0,0,0,5"/>
                                <TextBox x:Name="EditClassInput" Style="{StaticResource ModernTextBox}" Height="42"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Loại môn học" Foreground="#64748B" Margin="0,0,0,5"/>
                                <ComboBox x:Name="EditTypeInput" Tag="Chọn loại môn" Style="{StaticResource ModernComboBox}" SelectedIndex="0">
                                    <ComboBoxItem Content="Đại cương"/>
                                    <ComboBoxItem Content="Cơ sở ngành"/>
                                    <ComboBoxItem Content="Chuyên ngành"/>
                                    <ComboBoxItem Content="Đồ án"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Khoa" Foreground="#64748B" Margin="0,0,0,5"/>
                        <TextBox x:Name="EditCategoryInput" Style="{StaticResource ModernTextBox}" Height="42" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Học kỳ" Foreground="#64748B" Margin="0,0,0,5"/>
                                <ComboBox x:Name="EditSemesterInput" Tag="Chọn học kỳ" Style="{StaticResource ModernComboBox}" SelectedIndex="0">
                                    <ComboBoxItem Content="Học kỳ 1"/>
                                    <ComboBoxItem Content="Học kỳ 2"/>
                                    <ComboBoxItem Content="Học kỳ hè"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Năm học" Foreground="#64748B" Margin="0,0,0,5"/>
                                <ComboBox x:Name="EditYearInput" Tag="Chọn năm học" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Emoji" Foreground="#64748B" Margin="0,0,0,5"/>
                        <TextBox x:Name="EditEmojiInput" Style="{StaticResource ModernTextBox}" Width="60" Height="42" HorizontalAlignment="Left" Margin="0,0,0,15"/>

                        <TextBlock Text="Màu sắc chủ đề" Foreground="#64748B" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <RadioButton GroupName="ThemeColors" Background="#3B82F6" Style="{StaticResource ColorRadioStyle}" IsChecked="True"/>
                            <RadioButton GroupName="ThemeColors" Background="#8B5CF6" Style="{StaticResource ColorRadioStyle}"/>
                            <RadioButton GroupName="ThemeColors" Background="#F59E0B" Style="{StaticResource ColorRadioStyle}"/>
                            <RadioButton GroupName="ThemeColors" Background="#10B981" Style="{StaticResource ColorRadioStyle}"/>
                            <RadioButton GroupName="ThemeColors" Background="#EC4899" Style="{StaticResource ColorRadioStyle}"/>
                            <RadioButton GroupName="ThemeColors" Background="#64748B" Style="{StaticResource ColorRadioStyle}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Lưu thay đổi" Width="140" Height="42" Background="#3B82F6" Foreground="White" Click="ConfirmEdit_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Hủy" Margin="15,0,0,0" Background="Transparent" Foreground="#64748B" BorderThickness="0" Click="CloseEditDrawer_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid x:Name="NoteReaderDrawer" Visibility="Collapsed">
            <Border Background="#40000000" MouseLeftButtonDown="CloseNoteReader_Click"/>
            <Border HorizontalAlignment="Right" Background="White" Width="600" CornerRadius="20,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="-5" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="30,30,30,15">
                        <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="18" Foreground="#64748B" Cursor="Hand" Click="CloseNoteReader_Click"/>
                        <TextBlock x:Name="TxtNoteTitle" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Margin="30,0,30,30" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtNoteContent" FontSize="16" Foreground="#475569" TextWrapping="Wrap" LineHeight="26"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="AddContentDrawer" Visibility="Collapsed">
            <Border Background="#40000000" MouseLeftButtonDown="CloseAddDrawer_Click"/>
            <Border HorizontalAlignment="Right" Background="White" Width="500">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30">
                        <TextBlock x:Name="TxtContentFormTitle" Text="Thêm nội dung mới" FontSize="22" FontWeight="Bold" Margin="0,0,0,25"/>

                        <TextBlock Text="Loại nội dung" Foreground="#64748B" Margin="0,0,0,5"/>
                        <ComboBox x:Name="AddTypeInput" Tag="Chọn loại" Style="{StaticResource ModernComboBox}" Margin="0,0,0,15" SelectionChanged="AddTypeInput_SelectionChanged">
                            <ComboBoxItem Content="Document" IsSelected="True"/>
                            <ComboBoxItem Content="Link"/>
                            <ComboBoxItem Content="Note"/>
                        </ComboBox>

                        <TextBlock Text="Tiêu đề" Foreground="#64748B" Margin="0,0,0,5"/>
                        <TextBox x:Name="AddTitleInput" Style="{StaticResource ModernTextBox}" Height="42" Margin="0,0,0,15"/>

                        <Grid x:Name="InputAreaLink" Visibility="Collapsed" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Đường dẫn (URL)" Foreground="#64748B" Margin="0,0,0,5"/>
                                <TextBox x:Name="AddLinkInput" Style="{StaticResource ModernTextBox}" Height="42" Tag="https://..."/>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="InputAreaNote" Visibility="Collapsed" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Nội dung ghi chú" Foreground="#64748B" Margin="0,0,0,5"/>
                                <TextBox x:Name="AddNoteInput" Style="{StaticResource ModernTextBox}" Height="150" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="12,10"/>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="InputAreaDocument" Visibility="Visible" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Chọn tệp tài liệu" Foreground="#64748B" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="AddDocPathInput" Grid.Column="0" Style="{StaticResource ModernTextBox}" Height="42" IsReadOnly="True" Margin="0,0,10,0"/>
                                    <Button Grid.Column="1" Content="Thêm" Width="80" Height="42" Background="#F1F5F9" Foreground="#475569" FontWeight="SemiBold" Click="BtnBrowseFile_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button x:Name="BtnSubmitContent" Content="Thêm vào lớp" Width="140" Height="42" Background="#3B82F6" Foreground="White" Click="ConfirmAddContent_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Hủy" Margin="15,0,0,0" Background="Transparent" Foreground="#64748B" BorderThickness="0" Click="CloseAddDrawer_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

    </Grid>
</UserControl>