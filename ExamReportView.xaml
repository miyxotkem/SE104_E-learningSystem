<UserControl x:Class="e_learning_app.ExamReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Background="#F0F2F5"
             Loaded="UserControl_Loaded"
             d:DesignHeight="800" d:DesignWidth="1200">
    
    <UserControl.Resources>
        <!-- Styles -->
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="StatValueStyle">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="StatLabelStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style TargetType="Button" x:Key="BackButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="10,5" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Background="#99FFFFFF" Panel.ZIndex="100" Visibility="Visible">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Đang tải dữ liệu báo cáo..." FontSize="16" FontWeight="SemiBold" Foreground="#3B82F6"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="← Quay lại" Style="{StaticResource BackButtonStyle}" Click="BtnBack_Click" Margin="0,0,20,0"/>
                    
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="TxtExamTitle" Text="Bài kiểm tra: [Tên bài thi]" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock x:Name="TxtExamDesc" Text="[Mô tả]" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="2" Content="📥 Xuất Excel" Background="#10B981" Foreground="White" 
                            FontWeight="Bold" Padding="16,10" BorderThickness="0" Cursor="Hand"
                            Click="BtnExportExcel_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <!-- 1. Thống kê tổng quan -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Lượt nộp bài -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock x:Name="TxtTotalSubmissions" Text="0" Style="{StaticResource StatValueStyle}" Foreground="#3B82F6"/>
                            <TextBlock Text="Lượt nộp bài" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Tỷ lệ đạt -->
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock x:Name="TxtPassRate" Text="0%" Style="{StaticResource StatValueStyle}" Foreground="#10B981"/>
                            <TextBlock Text="Tỷ lệ đạt (>= 50%)" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Điểm Trung bình -->
                    <Border Grid.Column="4" Style="{StaticResource CardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock x:Name="TxtAvgScore" Text="0.0" Style="{StaticResource StatValueStyle}" Foreground="#F59E0B"/>
                            <TextBlock Text="Điểm trung bình" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Điểm Cao nhất -->
                    <Border Grid.Column="6" Style="{StaticResource CardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock x:Name="TxtMaxScore" Text="0.0" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="Điểm cao nhất" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Điểm Thấp nhất -->
                    <Border Grid.Column="8" Style="{StaticResource CardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock x:Name="TxtMinScore" Text="0.0" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="Điểm thấp nhất" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="6*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 2. Biểu đồ phân bố điểm -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Phân bố phổ điểm" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>
                            <StackPanel x:Name="DistributionPanel">
                                <!-- Bars will be injected here -->
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 3. Danh sách học sinh -->
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Chi tiết bài làm" FontSize="18" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                            </Grid>

                            <DataGrid x:Name="DgSubmissions" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                                      HeadersVisibility="Column" Background="White" BorderThickness="0"
                                      RowHeight="40" ColumnHeaderHeight="40" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="10,0"/>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="10,0"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                        <ContentPresenter VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Học sinh" Binding="{Binding StudentName}" Width="2*"/>
                                    <DataGridTextColumn Header="Thời gian nộp" Binding="{Binding SubmittedAt, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="1.5*"/>
                                    <DataGridTextColumn Header="Điểm" Binding="{Binding Score}" Width="*"/>
                                    <DataGridTextColumn Header="Phần trăm" Binding="{Binding Percentage, StringFormat=\{0:0.0\}%}" Width="*"/>
                                    <DataGridTextColumn Header="Thời gian làm" Binding="{Binding TimeSpentFormatted}" Width="1.5*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
