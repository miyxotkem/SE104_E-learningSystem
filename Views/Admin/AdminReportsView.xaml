<UserControl x:Class="e_learning_app.Views.Admin.AdminReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,30,32,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="📊  Báo cáo &amp; Thống kê" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Tổng hợp số liệu hoạt động của toàn hệ thống"
                           FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- SUMMARY CARDS -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Active sessions -->
                <Border Grid.Column="0" Background="White" CornerRadius="18" Padding="22,18">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.07" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border Width="42" Height="42" CornerRadius="13" HorizontalAlignment="Left">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                    <GradientStop Color="#4F46E5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TxtActiveUsers" Text="—" FontSize="30" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,8,0,0"/>
                        <TextBlock Text="Người dùng hoạt động" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Courses completed -->
                <Border Grid.Column="2" Background="White" CornerRadius="18" Padding="22,18">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.07" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border Width="42" Height="42" CornerRadius="13" Background="#F0FDF4" HorizontalAlignment="Left">
                            <TextBlock Text="✅" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TxtCompletedCourses" Text="—" FontSize="30" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,8,0,0"/>
                        <TextBlock Text="Khóa học hoàn thành" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Avg score -->
                <Border Grid.Column="4" Background="White" CornerRadius="18" Padding="22,18">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.07" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border Width="42" Height="42" CornerRadius="13" Background="#FFF7ED" HorizontalAlignment="Left">
                            <TextBlock Text="⭐" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TxtAvgScore" Text="—" FontSize="30" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,8,0,0"/>
                        <TextBlock Text="Điểm trung bình hệ thống" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- CHARTS PLACEHOLDER -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Enrollments by month -->
                <Border Grid.Column="0" Background="White" CornerRadius="18" Padding="22">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📈  Đăng ký theo tháng" FontSize="16" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,16"/>
                        <!-- Simulated bar chart -->
                        <Grid Height="180">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Bars -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Margin="6,0">
                                <TextBlock Text="12" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <Border Height="60" CornerRadius="6,6,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#4F46E5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="T11" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="6,0">
                                <TextBlock Text="24" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <Border Height="100" CornerRadius="6,6,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#4F46E5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="T12" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="6,0">
                                <TextBlock Text="18" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <Border Height="75" CornerRadius="6,6,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#4F46E5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="T1" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Margin="6,0">
                                <TextBlock Text="31" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <Border Height="130" CornerRadius="6,6,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#4F46E5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="T2" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Margin="6,0">
                                <TextBlock Text="27" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <Border Height="110" CornerRadius="6,6,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#4F46E5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="T3" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="5" VerticalAlignment="Bottom" Margin="6,0">
                                <TextBlock Text="42" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <Border Height="160" CornerRadius="6,6,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#4F46E5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="T4" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Role distribution -->
                <Border Grid.Column="2" Background="White" CornerRadius="18" Padding="22">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="🥧  Phân bố vai trò" FontSize="16" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,16"/>

                        <!-- Legend items with progress bars -->
                        <StackPanel Margin="0,0,0,12">
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Width="100">
                                    <Border Width="10" Height="10" CornerRadius="3" Background="#3B82F6" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Học viên" FontSize="12" Foreground="#1E293B" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Height="10" CornerRadius="5" Background="#E2E8F0" Margin="10,0">
                                    <Border HorizontalAlignment="Left" Width="NaN" CornerRadius="5" Background="#3B82F6"
                                            MinWidth="200" MaxWidth="200"/>
                                </Border>
                                <TextBlock x:Name="TxtStudentPct" Grid.Column="2" Text="75%" FontSize="12"
                                           FontWeight="Bold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Width="100">
                                    <Border Width="10" Height="10" CornerRadius="3" Background="#16A34A" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Giảng viên" FontSize="12" Foreground="#1E293B" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Height="10" CornerRadius="5" Background="#E2E8F0" Margin="10,0">
                                    <Border HorizontalAlignment="Left" CornerRadius="5" Background="#16A34A"
                                            MinWidth="66" MaxWidth="66"/>
                                </Border>
                                <TextBlock x:Name="TxtTeacherPct" Grid.Column="2" Text="25%" FontSize="12"
                                           FontWeight="Bold" Foreground="#16A34A" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- Export button -->
                        <Border CornerRadius="12" Padding="16,12" Margin="0,16,0,0" Cursor="Hand" HorizontalAlignment="Left">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                    <GradientStop Color="#4F46E5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📥" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="  Xuất báo cáo PDF" FontSize="13" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
